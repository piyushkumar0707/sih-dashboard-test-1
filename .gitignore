# ============================================================
# Travira — Monorepo .gitignore
# ============================================================

# ── Environment Variables ────────────────────────────────────
# NEVER commit secrets to git
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
*.env

# ── Node / npm ───────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*
package-lock.json
yarn.lock
.npm
.yarn/
.pnp.*
.node_repl_history
*.tgz
*.tar.gz
jspm_packages/
.yarn-integrity

# ── Frontend (React / CRA) ───────────────────────────────────
frontend/build/
frontend/.env*
frontend/node_modules/
frontend/package-lock.json

# ── Backend ──────────────────────────────────────────────────
backend/node_modules/
backend/package-lock.json
backend/.env*
backend/uploads/
backend/logs/

# ── Python / AI Services ─────────────────────────────────────
.venv/
venv/
env/
ENV/
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc
.Python
*.egg-info/
.eggs/
dist/
*.egg
*.whl
pip-log.txt
pip-delete-this-directory.txt
.hypothesis/
.pytest_cache/
.coverage
coverage.xml
*.cover
htmlcov/
.tox/
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/
.pyre/

# Trained ML model artifacts — large binary files
# AI_services/safety_score/model.pkl   ← keep if you want model in repo
# AI_services/safety_score/label_encoder.pkl
AI_services/safety_score/safety_dataset.csv
AI_services/safety_score/__pycache__/
AI_services/case_report/__pycache__/

# ── Blockchain / Hardhat ──────────────────────────────────────
Blockchain/node_modules/
Blockchain/package-lock.json
Blockchain/.env*
Blockchain/artifacts/
Blockchain/cache/
Blockchain/typechain/
Blockchain/typechain-types/
Blockchain/credentialsLog.json

# ── Android ──────────────────────────────────────────────────
# travira-android has its own .git — exclude from outer repo
travira-android/
travira-android/.kotlin/
travira-android/app/build/
travira-android/build/
travira-android/local.properties
travira-android/*.iml
travira-android/**/*.iml
*.apk
*.ap_
*.dex
*.class
.externalNativeBuild/
.cxx/
captures/

# ── Logs & Runtime ───────────────────────────────────────────
logs/
*.log
pids/
*.pid
*.seed
*.pid.lock

# ── Build outputs ────────────────────────────────────────────
build/
dist/
out/
.next/
.nuxt/
.cache/
.parcel-cache/

# ── Coverage ─────────────────────────────────────────────────
coverage/
.nyc_output/

# ── IDEs & Editors ───────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.project
.classpath
.settings/

# ── OS Generated ─────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Large / Auto-generated files ─────────────────────────────
repomix-output.xml
*.mp4
*.mov
*.avi
*.mkv

# ── Deployment / CI / start scripts ─────────────────────────
render.yaml
deploy.ps1
deploy.sh
start-all.ps1
start-all.sh

# ── Frontend deployment config ───────────────────────────────
vercel.json
# frontend/vercel.json is intentionally tracked (Vercel SPA routing)
frontend/.vercel/

# ── Legacy / duplicate server files ──────────────────────────
backend/index_old.js
backend/index_new.js
backend/seed_old.js
backend/seed_new.js

